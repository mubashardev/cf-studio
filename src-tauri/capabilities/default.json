{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "fs:default",
    "fs:allow-write-text-file",
    "allow-local-commands"
  ]
}